---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Adolxsense',
  description = 'Songs for the things we never said, the pain we never showed, and the memories that still echo.',
} = Astro.props;

const fullTitle = title === 'Adolxsense' ? title : `${title} — Adolxsense`;
const pathname = Astro.url.pathname;

const socials = [
  {
    name: 'TikTok',
    url: 'https://www.tiktok.com/@adolxsense',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/></svg>`,
  },
  {
    name: 'YouTube',
    url: 'https://www.youtube.com/@adolxsenseofficial',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
  },
  {
    name: 'Instagram',
    url: 'https://www.instagram.com/adolxsense',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>`,
  },
  {
    name: 'Facebook',
    url: 'https://www.facebook.com/adolxsense',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  },
  {
    name: 'X',
    url: 'https://x.com/adolxsense',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>`,
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#c0392b" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-M5SM5WTL9H"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-M5SM5WTL9H');
    </script>
  </head>
  <body>
    <nav class="nav" id="nav">
      <div class="nav__inner">
        <a href="/" class="nav__logo">
          <img src="/images/logo.svg" alt="Adolxsense" class="nav__logo-img" />
        </a>
        <ul class="nav__links">
          <li><a href="/" class={pathname === '/' ? 'active' : ''}>Home</a></li>
          <li><a href="/releases" class={pathname.startsWith('/releases') ? 'active' : ''}>Releases</a></li>
          <li><a href="/lyrics" class={pathname.startsWith('/lyrics') ? 'active' : ''}>Lyrics</a></li>
          <li><a href="/videos" class={pathname.startsWith('/videos') ? 'active' : ''}>Videos</a></li>
          <li><a href="/#about">About</a></li>
        </ul>
        <div class="nav__socials">
          {socials.map((s) => (
            <a href={s.url} target="_blank" rel="noopener noreferrer" class="social-icon" aria-label={s.name} set:html={s.icon} />
          ))}
        </div>
      </div>
    </nav>

    <slot />

    <footer class="footer">
      <div class="container">
        <div class="footer__inner">
          <div class="footer__logo">
            <img src="/images/logo.svg" alt="Adolxsense" class="footer__logo-img" />
          </div>

          <div class="footer__socials">
            {socials.map((s) => (
              <a href={s.url} target="_blank" rel="noopener noreferrer" class="social-icon social-icon--lg" aria-label={s.name} set:html={s.icon} />
            ))}
          </div>

          <ul class="footer__links">
            <li><a href="/">Home</a></li>
            <li><a href="/releases">Releases</a></li>
            <li><a href="/lyrics">Lyrics</a></li>
            <li><a href="/videos">Videos</a></li>
            <li><a href="/#about">About</a></li>
          </ul>
          <p class="footer__copy">
            &copy; {new Date().getFullYear()} Adolxsense. Songs for the things we never said.
          </p>
        </div>
      </div>
    </footer>

    <script>
      const nav = document.getElementById('nav');
      window.addEventListener('scroll', () => {
        nav?.classList.toggle('scrolled', window.scrollY > 40);
      }, { passive: true });
    </script>
  </body>
</html>
