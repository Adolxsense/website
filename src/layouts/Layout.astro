---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;   // absolute URL to OG image
  ogType?: string;    // defaults to 'website'
  jsonLd?: object;    // structured data object
}

const {
  title = 'Adolxsense',
  description = 'Songs for the things we never said, the pain we never showed, and the memories that still echo.',
  ogImage = 'https://adolxsense.com/images/banner/banner-1-1920w.webp',
  ogType = 'website',
  jsonLd,
} = Astro.props;

const fullTitle = title === 'Adolxsense' ? title : `${title} — Adolxsense`;
const pathname = Astro.url.pathname;
const canonicalUrl = `https://adolxsense.com${pathname}`;

const socials = [
  { name: 'TikTok',     url: 'https://www.tiktok.com/@adolxsense',           icon: 'fa-tiktok' },
  { name: 'YouTube',    url: 'https://www.youtube.com/@adolxsenseofficial',   icon: 'fa-youtube' },
  { name: 'Instagram',  url: 'https://www.instagram.com/adolxsense',          icon: 'fa-instagram' },
  { name: 'Facebook',   url: 'https://www.facebook.com/adolxsense',           icon: 'fa-facebook' },
  { name: 'X',          url: 'https://x.com/adolxsense',                      icon: 'fa-x-twitter' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <title>{fullTitle}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-192.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:site_name" content="Adolxsense" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1920" />
    <meta property="og:image:height" content="1080" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@adolxsense" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#c0392b" />

    <!-- JSON-LD Structured Data -->
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-M5SM5WTL9H"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-M5SM5WTL9H');
    </script>
  </head>
  <body>
    <nav class="nav" id="nav">
      <div class="nav__inner">
        <a href="/" class="nav__logo">
          <img src="/images/logo.svg" alt="Adolxsense" class="nav__logo-img" />
        </a>
        <ul class="nav__links">
          <li><a href="/" class={pathname === '/' ? 'active' : ''}>Home</a></li>
          <li><a href="/releases" class={pathname.startsWith('/releases') ? 'active' : ''}>Releases</a></li>
          <li><a href="/lyrics" class={pathname.startsWith('/lyrics') ? 'active' : ''}>Lyrics</a></li>
          <li><a href="/videos" class={pathname.startsWith('/videos') ? 'active' : ''}>Videos</a></li>
          <li><a href="/#about">About</a></li>
        </ul>
        <div class="nav__socials">
          {socials.map((s) => (
            <a href={s.url} target="_blank" rel="noopener noreferrer" class="social-icon" aria-label={s.name}>
              <i class={`fa-brands ${s.icon}`}></i>
            </a>
          ))}
        </div>
      </div>
    </nav>

    <slot />

    <footer class="footer">
      <div class="container">
        <div class="footer__inner">
          <div class="footer__logo">
            <img src="/images/logo.svg" alt="Adolxsense" class="footer__logo-img" />
          </div>

          <div class="footer__socials">
            {socials.map((s) => (
              <a href={s.url} target="_blank" rel="noopener noreferrer" class="social-icon social-icon--lg" aria-label={s.name}>
                <i class={`fa-brands ${s.icon}`}></i>
              </a>
            ))}
          </div>

          <ul class="footer__links">
            <li><a href="/">Home</a></li>
            <li><a href="/releases">Releases</a></li>
            <li><a href="/lyrics">Lyrics</a></li>
            <li><a href="/videos">Videos</a></li>
            <li><a href="/#about">About</a></li>
          </ul>
          <a href="mailto:hey@adolxsense.com" class="footer__email">hey@adolxsense.com</a>
          <p class="footer__copy">
            &copy; {new Date().getFullYear()} Adolxsense. Songs for the things we never said.
          </p>
        </div>
      </div>
    </footer>

    <script>
      const nav = document.getElementById('nav');
      window.addEventListener('scroll', () => {
        nav?.classList.toggle('scrolled', window.scrollY > 40);
      }, { passive: true });
    </script>
  </body>
</html>
