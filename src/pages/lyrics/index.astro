---
import Layout from '../../layouts/Layout.astro';
import { songs } from '../../data/songs';
---

<Layout title="Lyrics" description="All Adolxsense song lyrics — Nu Metal and Alternative Rock.">
  <div style="padding-top: 120px;">
    <div class="container">
      <div class="lyrics-hero">
        <p class="section-header__label">All Songs</p>
        <h1 class="section-header__title">Lyrics</h1>
      </div>

      <div style="padding: 80px 0;">
        <div class="songs-grid">
          {songs.map((song, i) => (
            <a href={`/lyrics/${song.slug}`} class="song-card">
              <div class="song-card__body">
                <span class="song-card__number">{String(i + 1).padStart(2, '0')}</span>
                <h3 class="song-card__title">{song.title}</h3>
                <div class="song-card__meta">
                  <span class="tag">{song.genre}</span>
                  <span class="tag">{song.album}</span>
                </div>
                <p class="song-card__desc">{song.description}</p>
                <span class="song-card__arrow">&#8594;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</Layout>
