---
import Layout from '../../layouts/Layout.astro';
import { songs, getSongBySlug } from '../../data/songs';
import { releases } from '../../data/releases';

export function getStaticPaths() {
  return songs.map((song) => ({
    params: { slug: song.slug },
  }));
}

const { slug } = Astro.params;
const song = getSongBySlug(slug);

if (!song) return Astro.redirect('/lyrics');

const release = releases.find((r) => r.tracks.some((t) => t.songSlug === slug));
const cover = release?.cover ?? null;

/**
 * Parses lyrics into blocks of section labels and lines.
 * Section labels match the pattern [Verse], [Chorus], etc.
 */
function parseLyrics(raw: string) {
  const lines = raw.split('\n');
  const blocks: Array<{ type: 'label' | 'line' | 'blank'; text: string }> = [];

  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed) {
      blocks.push({ type: 'blank', text: '' });
    } else if (/^\[.+\]$/.test(trimmed)) {
      blocks.push({ type: 'label', text: trimmed.replace(/^\[|\]$/g, '') });
    } else {
      blocks.push({ type: 'line', text: trimmed });
    }
  }

  return blocks;
}

const lyricBlocks = parseLyrics(song.lyrics);
const translationBlocks = song.translation ? parseLyrics(song.translation) : [];
const hasTranslation = translationBlocks.length > 0;

const ogImage = cover
  ? `https://adolxsense.com${cover.src}-1200w.webp`
  : 'https://adolxsense.com/images/banner/banner-1-1920w.webp';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MusicRecording',
  name: song.title,
  url: `https://adolxsense.com/lyrics/${song.slug}`,
  genre: song.genre,
  byArtist: {
    '@type': 'MusicGroup',
    name: 'Adolxsense',
    url: 'https://adolxsense.com',
  },
  ...(release && {
    inAlbum: {
      '@type': 'MusicAlbum',
      name: release.title,
      url: `https://adolxsense.com/releases/${release.slug}`,
    },
  }),
  ...(cover && { image: ogImage }),
};
---

<Layout
  title={song.title}
  description={song.description}
  ogType="music.song"
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <div style="padding-top: 100px; padding-bottom: 100px;">
    <div class="container">
      <a href="/lyrics" class="back-link reveal">&#8592; All Lyrics</a>

      <div class="song-detail-layout">
        <!-- LYRICS COLUMN -->
        <div>
          <div class="song-detail-header reveal">
            <h1 class="song-detail-title">{song.title}</h1>
            <div class="song-detail-meta">
              <span class="tag">{song.genre}</span>
              <span class="tag">{song.bpm} BPM</span>
              <span class="tag">{song.album}</span>
              <span class="tag">{song.year}</span>
            </div>
            <p class="song-detail-desc">{song.description}</p>
          </div>

          {hasTranslation ? (
            <div class="lyrics-dual reveal" style="--reveal-delay: 1">
              <div class="lyrics-dual__col">
                <p class="lyrics-dual__lang">English</p>
                <div class="lyrics-body">
                  {lyricBlocks.map((block) => {
                    if (block.type === 'label') return <span class="section-label">[{block.text}]</span>;
                    if (block.type === 'line') return <span class="line">{block.text}</span>;
                    return <br />;
                  })}
                </div>
              </div>
              <div class="lyrics-dual__divider"></div>
              <div class="lyrics-dual__col">
                <p class="lyrics-dual__lang">Portuguese</p>
                <div class="lyrics-body">
                  {translationBlocks.map((block) => {
                    if (block.type === 'label') return <span class="section-label">[{block.text}]</span>;
                    if (block.type === 'line') return <span class="line">{block.text}</span>;
                    return <br />;
                  })}
                </div>
              </div>
            </div>
          ) : (
            <div class="lyrics-body reveal" style="--reveal-delay: 1">
              {lyricBlocks.map((block) => {
                if (block.type === 'label') return <span class="section-label">[{block.text}]</span>;
                if (block.type === 'line') return <span class="line">{block.text}</span>;
                return <br />;
              })}
            </div>
          )}
        </div>

        <!-- VIDEO / COVER COLUMN -->
        <div class="song-video reveal" style="--reveal-delay: 2">
          {cover && (
            <div class="song-cover">
              <picture>
                <source
                  srcset={`${cover.src}-600w.webp 600w, ${cover.src}-300w.webp 300w`}
                  sizes="(max-width: 768px) 100vw, 340px"
                  type="image/webp"
                />
                <img
                  src={`${cover.src}.jpg`}
                  alt={cover.alt}
                  class="song-cover-img"
                  width="600"
                  height="600"
                />
              </picture>
            </div>
          )}
          <div class="song-video-embed" style={cover ? 'margin-top: 16px;' : ''}>
            {song.youtubeId ? (
              <iframe
                src={`https://www.youtube.com/embed/${song.youtubeId}`}
                title={song.title}
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              />
            ) : (
              <div class="song-video-placeholder">
                <div style="font-size: 2rem; margin-bottom: 8px; opacity: 0.3;">&#9654;</div>
                <span>Video coming soon</span>
              </div>
            )}
          </div>

          <div style="margin-top: 32px; padding: 24px; background: var(--bg-card); border: 1px solid var(--border);">
            <p style="font-family: var(--font-heading); font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-faint); margin-bottom: 16px;">Track Info</p>
            <div style="display: flex; flex-direction: column; gap: 10px;">
              <div style="display: flex; justify-content: space-between; font-size: 0.85rem;">
                <span style="color: var(--text-muted);">Release</span>
                <span style="color: var(--text);">{song.album}</span>
              </div>
              {song.releaseDate && (
                <div style="display: flex; justify-content: space-between; font-size: 0.85rem;">
                  <span style="color: var(--text-muted);">Date</span>
                  <span style="color: var(--text);">{song.releaseDate}</span>
                </div>
              )}
              {song.label && (
                <div style="display: flex; justify-content: space-between; font-size: 0.85rem;">
                  <span style="color: var(--text-muted);">Label</span>
                  <span style="color: var(--text);">{song.label}</span>
                </div>
              )}
              <div style="display: flex; justify-content: space-between; font-size: 0.85rem;">
                <span style="color: var(--text-muted);">Genre</span>
                <span style="color: var(--text);">{song.genre}</span>
              </div>
              <div style="display: flex; justify-content: space-between; font-size: 0.85rem;">
                <span style="color: var(--text-muted);">BPM</span>
                <span style="color: var(--text);">{song.bpm}</span>
              </div>
              <div style="display: flex; justify-content: space-between; font-size: 0.85rem;">
                <span style="color: var(--text-muted);">Year</span>
                <span style="color: var(--text);">{song.year}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
