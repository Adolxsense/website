---
import Layout from '../../layouts/Layout.astro';
import { releases } from '../../data/releases';
---

<Layout title="Releases" description="All Adolxsense releases — albums, singles, EPs and LPs.">
  <div style="padding-top: 120px; padding-bottom: 100px;">
    <div class="container">
      <div class="lyrics-hero">
        <p class="section-header__label">Discography</p>
        <h1 class="section-header__title">Releases</h1>
      </div>

      <div style="padding-top: 80px;">
        <div class="releases-grid">
          {releases.map((release) => (
            <a href={`/releases/${release.slug}`} class="release-card">
              <div class="release-card__cover">
                {release.cover ? (
                  <picture>
                    <source
                      srcset={`${release.cover.src}-300w.webp`}
                      type="image/webp"
                    />
                    <img
                      src={`${release.cover.src}.jpg`}
                      alt={release.cover.alt}
                      class="release-card__cover-img"
                      loading="lazy"
                      width="300"
                      height="300"
                    />
                  </picture>
                ) : (
                  <div class="release-card__title-overlay">{release.title}</div>
                )}
                <span class="release-card__type-badge">{release.type}</span>
              </div>
              <div class="release-card__info">
                <h3 class="release-card__name">{release.title}</h3>
                <div class="release-card__meta">
                  <span style="color: var(--text-muted); font-size: 0.82rem;">{release.releaseDate}</span>
                </div>
                <p class="release-card__tracks">{release.tracks.length} track{release.tracks.length !== 1 ? 's' : ''}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</Layout>
