---
import Layout from '../../layouts/Layout.astro';
import { releases, getReleaseBySlug } from '../../data/releases';

export function getStaticPaths() {
  return releases.map((r) => ({ params: { slug: r.slug } }));
}

const { slug } = Astro.params;
const release = getReleaseBySlug(slug);

if (!release) return Astro.redirect('/releases');
---

<Layout title={release.title} description={`${release.type} · ${release.releaseDate} · Adolxsense`}>
  <div style="padding-top: 100px; padding-bottom: 100px;">
    <div class="container">
      <a href="/releases" class="back-link">&#8592; All Releases</a>

      <div class="release-detail-layout">
        <!-- LEFT: cover + info -->
        <div class="release-detail-left">
          <div class="release-detail-cover">
            {release.cover ? (
              <picture>
                <source
                  srcset={`${release.cover.src}-600w.webp 600w, ${release.cover.src}-300w.webp 300w`}
                  sizes="(max-width: 768px) 100vw, 280px"
                  type="image/webp"
                />
                <img
                  src={`${release.cover.src}.jpg`}
                  alt={release.cover.alt}
                  class="release-detail-cover-img"
                  width="600"
                  height="600"
                />
              </picture>
            ) : (
              <>
                <span class="release-detail-cover__type">{release.type}</span>
                <div class="release-detail-cover__title">{release.title}</div>
              </>
            )}
          </div>

          <div class="release-detail-meta-box">
            <p style="font-family: var(--font-heading); font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-faint); margin-bottom: 16px;">Info</p>
            <div style="display: flex; flex-direction: column; gap: 10px;">
              <div class="release-meta-row">
                <span>Type</span><span>{release.type}</span>
              </div>
              <div class="release-meta-row">
                <span>Released</span><span>{release.releaseDate}</span>
              </div>
              {release.label && (
                <div class="release-meta-row">
                  <span>Label</span><span>{release.label}</span>
                </div>
              )}
              {release.upc && (
                <div class="release-meta-row">
                  <span>UPC</span><span style="font-size:0.78rem;">{release.upc}</span>
                </div>
              )}
              <div class="release-meta-row">
                <span>Tracks</span><span>{release.tracks.length}</span>
              </div>
            </div>
            {(release.spotifyUrl || release.appleMusicUrl) && (
              <div class="streaming-links">
                {release.spotifyUrl && (
                  <a href={release.spotifyUrl} target="_blank" rel="noopener noreferrer" class="streaming-btn streaming-btn--spotify" aria-label="Listen on Spotify">
                    <i class="fa-brands fa-spotify"></i>
                    Spotify
                  </a>
                )}
                {release.appleMusicUrl && (
                  <a href={release.appleMusicUrl} target="_blank" rel="noopener noreferrer" class="streaming-btn streaming-btn--apple" aria-label="Listen on Apple Music">
                    <i class="fa-brands fa-apple"></i>
                    Apple Music
                  </a>
                )}
              </div>
            )}
          </div>
        </div>

        <!-- RIGHT: tracklist -->
        <div class="release-detail-right">
          <div class="release-detail-header">
            <h1 class="song-detail-title">{release.title}</h1>
            <div style="display: flex; gap: 8px; margin-bottom: 12px;">
              <span class="tag">{release.type}</span>
              <span class="tag">{release.releaseDate}</span>
            </div>
            {release.description && (
              <p class="song-detail-desc">{release.description}</p>
            )}
          </div>

          <div class="tracklist">
            <p class="tracklist__heading">Tracklist</p>
            <ol class="tracklist__items">
              {release.tracks.map((track, i) => (
                <li class="tracklist__item">
                  <span class="tracklist__number">{String(i + 1).padStart(2, '0')}</span>
                  <span class="tracklist__title">{track.title}</span>
                  {track.songSlug ? (
                    <a href={`/lyrics/${track.songSlug}`} class="tracklist__lyrics-btn">
                      Lyrics &#8594;
                    </a>
                  ) : (
                    <span class="tracklist__no-lyrics">—</span>
                  )}
                </li>
              ))}
            </ol>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
