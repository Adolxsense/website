---
import Layout from '../../layouts/Layout.astro';
import { releases, getReleaseBySlug } from '../../data/releases';

export function getStaticPaths() {
  return releases.map((r) => ({ params: { slug: r.slug } }));
}

const { slug } = Astro.params;
const release = getReleaseBySlug(slug);

if (!release) return Astro.redirect('/releases');

/** Convert a Spotify URL to its embed URL with dark theme */
function spotifyEmbedUrl(url: string): string | null {
  const match = url.match(/open\.spotify\.com\/(album|playlist|track)\/([a-zA-Z0-9]+)/);
  if (!match) return null;
  return `https://open.spotify.com/embed/${match[1]}/${match[2]}?utm_source=generator&theme=0`;
}

const spotifyEmbed = release.spotifyUrl ? spotifyEmbedUrl(release.spotifyUrl) : null;

const ogImage = release.cover
  ? `https://adolxsense.com${release.cover.src}-1200w.webp`
  : 'https://adolxsense.com/images/banner/banner-1-1920w.webp';

const releaseTypeMap: Record<string, string> = {
  Single: 'SingleRelease',
  EP: 'EPRelease',
  LP: 'AlbumRelease',
  Album: 'AlbumRelease',
};

const artist = {
  '@type': 'MusicGroup',
  name: 'Adolxsense',
  url: 'https://adolxsense.com',
  sameAs: [
    'https://open.spotify.com/artist/0E2Sa4BxDqWcleazYE7lUT',
    'https://music.apple.com/br/artist/adolxsense/1848634461',
    'https://www.youtube.com/@adolxsenseofficial',
    'https://www.instagram.com/adolxsense',
    'https://www.tiktok.com/@adolxsense',
  ],
};

const releaseUrl = `https://adolxsense.com/releases/${release.slug}`;

const streamingOffers = [
  ...(release.spotifyUrl ? [{
    '@type': 'Offer',
    url: release.spotifyUrl,
    seller: { '@type': 'Organization', name: 'Spotify' },
    availability: 'https://schema.org/InStock',
    price: '0',
    priceCurrency: 'USD',
    category: 'StreamingService',
  }] : []),
  ...(release.appleMusicUrl ? [{
    '@type': 'Offer',
    url: release.appleMusicUrl,
    seller: { '@type': 'Organization', name: 'Apple Music' },
    availability: 'https://schema.org/InStock',
    price: '0',
    priceCurrency: 'USD',
    category: 'StreamingService',
  }] : []),
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MusicAlbum',
  '@id': releaseUrl,
  name: release.title,
  url: releaseUrl,
  datePublished: release.releaseDate,
  copyrightYear: release.year,
  albumProductionType: 'https://schema.org/StudioAlbum',
  albumReleaseType: `https://schema.org/${releaseTypeMap[release.type] ?? 'AlbumRelease'}`,
  genre: ['Nu Metal', 'Alternative Rock', 'Post-Grunge'],
  inLanguage: 'en',
  byArtist: artist,
  ...(release.cover && { image: ogImage }),
  ...(release.description && { description: release.description }),
  ...(release.label && {
    recordLabel: {
      '@type': 'Organization',
      name: release.label,
    },
  }),
  ...(release.upc && { gtin13: release.upc }),
  numTracks: release.tracks.length,
  track: release.tracks.map((t, i) => ({
    '@type': 'MusicRecording',
    name: t.title,
    position: i + 1,
    byArtist: artist,
    inAlbum: { '@id': releaseUrl },
    ...(t.songSlug && { url: `https://adolxsense.com/lyrics/${t.songSlug}` }),
  })),
  ...(streamingOffers.length > 0 && { offers: streamingOffers }),
  sameAs: [
    ...(release.spotifyUrl ? [release.spotifyUrl] : []),
    ...(release.appleMusicUrl ? [release.appleMusicUrl] : []),
    ...(release.promotionUrl ? [release.promotionUrl] : []),
  ],
  potentialAction: [
    ...(release.spotifyUrl ? [{
      '@type': 'ListenAction',
      target: { '@type': 'EntryPoint', urlTemplate: release.spotifyUrl },
      expectsAcceptanceOf: {
        '@type': 'Offer',
        seller: { '@type': 'Organization', name: 'Spotify' },
      },
    }] : []),
    ...(release.appleMusicUrl ? [{
      '@type': 'ListenAction',
      target: { '@type': 'EntryPoint', urlTemplate: release.appleMusicUrl },
      expectsAcceptanceOf: {
        '@type': 'Offer',
        seller: { '@type': 'Organization', name: 'Apple Music' },
      },
    }] : []),
  ],
};
---

<Layout
  title={release.title}
  description={release.description
    ? `${release.description} ${release.type} by Adolxsense — released ${release.releaseDate}.`
    : `${release.title} — ${release.type} by Adolxsense. Released ${release.releaseDate}. Stream on Spotify and Apple Music.`}
  ogType="music.album"
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <div style="padding-top: 100px; padding-bottom: 100px;">
    <div class="container">
      <a href="/releases" class="back-link">&#8592; All Releases</a>

      <div class="release-detail-layout">
        <!-- LEFT: cover + info -->
        <div class="release-detail-left">
          <div class="release-detail-cover">
            {release.cover ? (
              <picture>
                <source
                  srcset={`${release.cover.src}-600w.webp 600w, ${release.cover.src}-300w.webp 300w`}
                  sizes="(max-width: 768px) 100vw, 280px"
                  type="image/webp"
                />
                <img
                  src={`${release.cover.src}.jpg`}
                  alt={release.cover.alt}
                  class="release-detail-cover-img"
                  width="600"
                  height="600"
                />
              </picture>
            ) : (
              <>
                <span class="release-detail-cover__type">{release.type}</span>
                <div class="release-detail-cover__title">{release.title}</div>
              </>
            )}
          </div>

          <div class="release-detail-meta-box">
            <p style="font-family: var(--font-heading); font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-faint); margin-bottom: 16px;">Info</p>
            <div style="display: flex; flex-direction: column; gap: 10px;">
              <div class="release-meta-row">
                <span>Type</span><span>{release.type}</span>
              </div>
              <div class="release-meta-row">
                <span>Released</span><span>{release.releaseDate}</span>
              </div>
              {release.label && (
                <div class="release-meta-row">
                  <span>Label</span><span>{release.label}</span>
                </div>
              )}
              {release.upc && (
                <div class="release-meta-row">
                  <span>UPC</span><span style="font-size:0.78rem;">{release.upc}</span>
                </div>
              )}
              <div class="release-meta-row">
                <span>Tracks</span><span>{release.tracks.length}</span>
              </div>
            </div>
            {(release.spotifyUrl || release.appleMusicUrl) && (
              <div class="streaming-links">
                {release.spotifyUrl && (
                  <a href={release.spotifyUrl} target="_blank" rel="noopener noreferrer" class="streaming-btn streaming-btn--spotify" aria-label="Listen on Spotify">
                    <i class="fa-brands fa-spotify"></i>
                    Spotify
                  </a>
                )}
                {release.appleMusicUrl && (
                  <a href={release.appleMusicUrl} target="_blank" rel="noopener noreferrer" class="streaming-btn streaming-btn--apple" aria-label="Listen on Apple Music">
                    <i class="fa-brands fa-apple"></i>
                    Apple Music
                  </a>
                )}
              </div>
            )}
          </div>

          {spotifyEmbed && (
            <div class="spotify-embed">
              <iframe
                src={spotifyEmbed}
                width="100%"
                height="352"
                frameborder="0"
                allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                loading="lazy"
                title={`${release.title} on Spotify`}
              ></iframe>
            </div>
          )}
        </div>

        <!-- RIGHT: tracklist -->
        <div class="release-detail-right">
          <div class="release-detail-header">
            <h1 class="song-detail-title">{release.title}</h1>
            <div style="display: flex; gap: 8px; margin-bottom: 12px;">
              <span class="tag">{release.type}</span>
              <span class="tag">{release.releaseDate}</span>
            </div>
            {release.description && (
              <p class="song-detail-desc">{release.description}</p>
            )}
          </div>

          <div class="tracklist">
            <p class="tracklist__heading">Tracklist</p>
            <ol class="tracklist__items">
              {release.tracks.map((track, i) => (
                <li class="tracklist__item">
                  <span class="tracklist__number">{String(i + 1).padStart(2, '0')}</span>
                  <span class="tracklist__title">{track.title}</span>
                  {track.songSlug ? (
                    <a href={`/lyrics/${track.songSlug}`} class="tracklist__lyrics-btn">
                      Lyrics &#8594;
                    </a>
                  ) : (
                    <span class="tracklist__no-lyrics">—</span>
                  )}
                </li>
              ))}
            </ol>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
