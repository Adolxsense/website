---
import Layout from '../layouts/Layout.astro';
import { songs } from '../data/songs';
import { releases } from '../data/releases';

const featuredSongs = songs.slice(0, 4);
const latestReleases = releases.slice(0, 3);

/** Map: songSlug → release cover */
const coverBySong = Object.fromEntries(
  releases
    .filter((r) => r.cover)
    .flatMap((r) => r.tracks.filter((t) => t.songSlug).map((t) => [t.songSlug!, r.cover!]))
);
---

<Layout>
  <!-- HERO -->
  <section class="hero">
    <!-- Rotating banner images -->
    <div class="hero__slides">
      <div class="banner-slide active">
        <img
          srcset="/images/banner/banner-1-480w.webp 480w, /images/banner/banner-1-768w.webp 768w, /images/banner/banner-1-1280w.webp 1280w, /images/banner/banner-1-1920w.webp 1920w"
          sizes="100vw"
          src="/images/banner/banner-1-1920w.webp"
          alt="" class="banner-slide__img" fetchpriority="high"
        />
      </div>
      <div class="banner-slide">
        <img
          srcset="/images/banner/banner-2-480w.webp 480w, /images/banner/banner-2-768w.webp 768w, /images/banner/banner-2-1280w.webp 1280w, /images/banner/banner-2-1920w.webp 1920w"
          sizes="100vw"
          src="/images/banner/banner-2-1920w.webp"
          alt="" class="banner-slide__img" loading="lazy"
        />
      </div>
      <div class="banner-slide">
        <img
          srcset="/images/banner/banner-3-480w.webp 480w, /images/banner/banner-3-768w.webp 768w, /images/banner/banner-3-1280w.webp 1280w, /images/banner/banner-3-1920w.webp 1920w"
          sizes="100vw"
          src="/images/banner/banner-3-1920w.webp"
          alt="" class="banner-slide__img" loading="lazy"
        />
      </div>
      <div class="banner-slide">
        <img
          srcset="/images/banner/banner-4-480w.webp 480w, /images/banner/banner-4-768w.webp 768w, /images/banner/banner-4-1280w.webp 1280w, /images/banner/banner-4-1920w.webp 1920w"
          sizes="100vw"
          src="/images/banner/banner-4-1920w.webp"
          alt="" class="banner-slide__img" loading="lazy"
        />
      </div>
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__grid"></div>
    <div class="hero__scroll">
      <div class="hero__scroll-line"></div>
      <span>Scroll</span>
    </div>
    <div class="hero__dots">
      <button class="hero__dot active" data-index="0" aria-label="Slide 1"></button>
      <button class="hero__dot" data-index="1" aria-label="Slide 2"></button>
      <button class="hero__dot" data-index="2" aria-label="Slide 3"></button>
      <button class="hero__dot" data-index="3" aria-label="Slide 4"></button>
    </div>
  </section>

  <script>
    const slides = Array.from(document.querySelectorAll('.banner-slide'));
    const dots   = Array.from(document.querySelectorAll('.hero__dot'));
    let current  = 0;
    let timer: ReturnType<typeof setInterval>;

    function goTo(index: number) {
      slides[current].classList.remove('active');
      dots[current].classList.remove('active');
      current = index;
      slides[current].classList.add('active');
      dots[current].classList.add('active');
    }

    function next() {
      goTo((current + 1) % slides.length);
    }

    function startTimer() {
      timer = setInterval(next, 6000);
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        clearInterval(timer);
        goTo(Number(dot.dataset.index));
        startTimer();
      });
    });

    startTimer();
  </script>

  <!-- LISTEN NOW STRIP -->
  <div class="listen-strip">
    <div class="container">
      <div class="listen-strip__inner">
        <p class="listen-strip__label">Listen on</p>
        <div class="listen-strip__links">
          <a href="https://open.spotify.com/artist/0E2Sa4BxDqWcleazYE7lUT?si=ILUDQ_W6SMO6fO95WEufxg" target="_blank" rel="noopener noreferrer" class="listen-btn listen-btn--spotify">
            <i class="fa-brands fa-spotify"></i>
            Spotify
          </a>
          <a href="https://music.apple.com/br/artist/adolxsense/1848634461" target="_blank" rel="noopener noreferrer" class="listen-btn listen-btn--apple">
            <i class="fa-brands fa-apple"></i>
            Apple Music
          </a>
        </div>
        <div class="listen-strip__divider"></div>
        <div class="listen-strip__links">
          <p class="listen-strip__label">Featured Playlist</p>
          <a href="https://open.spotify.com/playlist/6vC0LHXP8eHQ69mUJwhvp4?si=43da85891933462f" target="_blank" rel="noopener noreferrer" class="listen-btn listen-btn--playlist listen-btn--spotify">
            <i class="fa-brands fa-spotify"></i>
            This is Adolxsense
          </a>
          <a href="https://music.apple.com/br/playlist/this-is-adolxsense/pl.u-XkD0YzJS4o2p4G?l=en" target="_blank" rel="noopener noreferrer" class="listen-btn listen-btn--playlist listen-btn--apple">
            <i class="fa-brands fa-apple"></i>
            This is Adolxsense
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- LATEST RELEASES SECTION -->
  <section class="section" id="releases-home">
    <div class="container">
      <div class="section-header">
        <p class="section-header__label">Discography</p>
        <h2 class="section-header__title">Latest <em>Releases</em></h2>
      </div>
      <div class="home-releases-grid">
        {latestReleases.map((release) => (
          <div class="home-release-card">
            <a href={`/releases/${release.slug}`} class="home-release-card__cover-link">
              <div class="home-release-card__cover">
                {release.cover ? (
                  <picture>
                    <source
                      srcset={`${release.cover.src}-600w.webp 600w, ${release.cover.src}-300w.webp 300w`}
                      sizes="(max-width: 768px) 100vw, 400px"
                      type="image/webp"
                    />
                    <img
                      src={`${release.cover.src}.jpg`}
                      alt={release.cover.alt}
                      class="home-release-card__img"
                      loading="lazy"
                      width="600"
                      height="600"
                    />
                  </picture>
                ) : (
                  <div class="home-release-card__placeholder">{release.title}</div>
                )}
                <span class="release-card__type-badge">{release.type}</span>
              </div>
            </a>
            <div class="home-release-card__info">
              <a href={`/releases/${release.slug}`} class="home-release-card__title">{release.title}</a>
              <p class="home-release-card__date">{release.releaseDate}</p>
              {release.label && <p class="home-release-card__label">{release.label}</p>}
              <div class="home-release-card__streaming">
                {release.spotifyUrl && (
                  <a href={release.spotifyUrl} target="_blank" rel="noopener noreferrer" class="streaming-btn streaming-btn--spotify" aria-label="Listen on Spotify">
                    <i class="fa-brands fa-spotify"></i>
                    Spotify
                  </a>
                )}
                {release.appleMusicUrl && (
                  <a href={release.appleMusicUrl} target="_blank" rel="noopener noreferrer" class="streaming-btn streaming-btn--apple" aria-label="Listen on Apple Music">
                    <i class="fa-brands fa-apple"></i>
                    Apple Music
                  </a>
                )}
              </div>
              <a href={`/releases/${release.slug}`} class="home-release-card__more">
                View release &#8594;
              </a>
            </div>
          </div>
        ))}
      </div>
      <div style="margin-top: 48px; text-align: center;">
        <a href="/releases" class="btn btn-ghost">All Releases &#8594;</a>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- LATEST LYRICS SECTION -->
  <section class="section" id="music">
    <div class="container">
      <div class="section-header">
        <p class="section-header__label">Lyrics</p>
        <h2 class="section-header__title">Latest <em>Lyrics</em></h2>
      </div>
      <div class="songs-grid">
        {featuredSongs.map((song, i) => {
          const cover = coverBySong[song.slug];
          return (
            <a href={`/lyrics/${song.slug}`} class="song-card">
              {cover && (
                <div class="song-card__cover">
                  <picture>
                    <source srcset={`${cover.src}-300w.webp`} type="image/webp" />
                    <img
                      src={`${cover.src}.jpg`}
                      alt={cover.alt}
                      class="song-card__cover-img"
                      loading="lazy"
                      width="300"
                      height="300"
                    />
                  </picture>
                </div>
              )}
              <div class="song-card__body">
                <span class="song-card__number">0{i + 1}</span>
                <h3 class="song-card__title">{song.title}</h3>
                <div class="song-card__meta">
                  <span class="tag">{song.genre}</span>
                  <span class="tag">{song.bpm} BPM</span>
                </div>
                <p class="song-card__desc">{song.description}</p>
                <span class="song-card__arrow">&#8594;</span>
              </div>
            </a>
          );
        })}
      </div>
      <div style="margin-top: 48px; text-align: center;">
        <a href="/lyrics" class="btn btn-ghost">View All Lyrics &#8594;</a>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ABOUT SECTION -->
  <section class="section about-section" id="about">
    <div class="container">
      <div class="about-layout">
        <div class="about-big-text">
          THE<br />
          <span>BAND</span>
        </div>
        <div class="about-body">
          <p class="section-header__label" style="margin-bottom: 20px;">About Adolxsense</p>
          <p>
            <strong>Adolxsense</strong> is a Nu Metal and Alternative Rock project built on a simple belief:
            music should make you feel something you can't find words for — and then give you the words.
          </p>
          <p>
            Fronted by the raw, confessional voice of <strong>Christie</strong> (Christine Noelle Lavigne),
            the band channels early-2000s rock energy through a modern lens — heavy distorted guitars,
            cinematic atmospheres, and lyrics that live in the spaces between what we say and what we mean.
          </p>
          <p>
            Drawing from the sonic DNA of Linkin Park, Evanescence, Breaking Benjamin, and Staind,
            Adolxsense exists in a world of dark corridors, empty roads, and the quiet devastation
            of things left unsaid.
          </p>
          <div class="about-quote">
            <blockquote>
              "Songs for the things we never said, the pain we never showed,<br />
              and the memories that still echo."
            </blockquote>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- VIDEOS PREVIEW -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="section-header__label">Watch</p>
        <h2 class="section-header__title">Latest <em>Videos</em></h2>
      </div>
      <div class="videos-grid">
        {songs.slice(0, 3).map((song) => (
          <div class="video-card">
            <div class="video-card__embed">
              {song.youtubeId ? (
                <iframe
                  src={`https://www.youtube.com/embed/${song.youtubeId}`}
                  title={song.title}
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                />
              ) : (
                <div class="video-card__placeholder">
                  <div class="video-card__placeholder-icon">&#9654;</div>
                  <span>Coming Soon</span>
                </div>
              )}
            </div>
            <div class="video-card__info">
              <div class="video-card__title">{song.title}</div>
              <div class="video-card__album">{song.album}</div>
            </div>
          </div>
        ))}
      </div>
      <div style="margin-top: 48px; text-align: center;">
        <a href="/videos" class="btn btn-ghost">All Videos &#8594;</a>
      </div>
    </div>
  </section>
</Layout>
